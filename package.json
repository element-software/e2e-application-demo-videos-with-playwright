{
  "name": "e2e-application-demo-videos-with-playwright",
  "private": true,
  "version": "0.1.0",
  "description": "Generate full application demo videos using Playwright and ffmpeg",
  "scripts": {
    "app:install": "npm install --prefix app",
    "app:dev": "npm run dev --prefix app",
    "app:build": "npm run build --prefix app",
    "app:preview": "npm run preview --prefix app",
    "demo:video:capture": "npx playwright test",
    "demo:video:render": "node scripts/render-video.mjs",
    "demo:video": "npm run demo:video:capture && npm run demo:video:render",
    "prayertimes:demo:capture": "npx playwright test --config playwright.prayertimes.config.ts e2e/prayertimes-demo.spec.ts",
    "prayertimes:demo:render": "node scripts/render-video.mjs --config demo.prayertimes.config.mjs",
    "prayertimes:demo": "npm run prayertimes:demo:capture && npm run prayertimes:demo:render",
    "prayertimes:reel:capture": "npx playwright test --config playwright.prayertimes.config.ts e2e/prayertimes-demo-mobile.spec.ts",
    "prayertimes:reel:render": "node scripts/render-video.mjs --config demo.prayertimes-mobile.config.mjs",
    "prayertimes:reel": "npm run prayertimes:reel:capture && npm run prayertimes:reel:render"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^6.0.3"
  }
}
